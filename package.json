{
  "name": "vivd-root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace=@vivd/shared",
    "test": "concurrently \"npm run test --workspace=@vivd/backend\" \"npm run test --workspace=@vivd/frontend\" \"npm run test --workspace=@vivd/scraper\"",
    "test:run": "npm run test:run --workspace=@vivd/backend && npm run test:run --workspace=@vivd/frontend && npm run test:run --workspace=@vivd/scraper",
    "test:integration": "npm run test:integration --workspace=@vivd/backend --",
    "lint": "npm run lint --workspace=@vivd/frontend",
    "check": "npm run lint && npm run test:run",
    "ci:local": "./scripts/ci-local.sh",
    "ci:local:tests": "./scripts/ci-local.sh --skip-lint",
    "ci:local:integration": "./scripts/ci-local.sh --db-integration --bucket-integration",
    "ci:local:full": "./scripts/ci-local.sh --build --db-integration --bucket-integration",
    "ci:local:fly": "./scripts/ci-local.sh --db-integration --bucket-integration --fly-integration",
    "db:studio": "npm run db:studio --workspace=@vivd/backend",
    "db:generate": "npm run db:generate --workspace=@vivd/backend",
    "db:migrate": "npm run db:migrate --workspace=@vivd/backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
