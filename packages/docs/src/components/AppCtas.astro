---
import { showOperatorGuides } from "../lib/docsFlags";

const {
  title = "Start with Vivd",
  description = "Request hosted access, browse the docs, or inspect the public codebase.",
} = Astro.props;
---

<section class="app-ctas">
  <div class="app-ctas-copy">
    <p class="eyebrow">Try it</p>
    <h2>{title}</h2>
    <p>{description}</p>
  </div>
  <div class="app-ctas-links">
    <a class="button-primary" href={showOperatorGuides ? "/self-hosting/" : "/getting-started/"}>
      {showOperatorGuides ? "Operator guides" : "Getting Started"}
    </a>
    <a class="button-secondary" href="https://vivd.studio/services.html#contact">Request closed beta access</a>
    <a class="button-tertiary" href="https://github.com/vivd-studio/vivd">GitHub</a>
  </div>
</section>
