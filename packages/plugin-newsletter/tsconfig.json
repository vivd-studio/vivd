{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../frontend/src/*"],
      "@vivd/backend/*": ["../backend/*"],
      "@vivd/builder": ["../builder/src/index.ts"],
      "@vivd/builder/*": ["../builder/src/*"],
      "@vivd/plugin-analytics": ["../plugin-analytics/src/index.ts"],
      "@vivd/plugin-analytics/*": ["../plugin-analytics/src/*"],
      "@vivd/plugin-contact-form": ["../plugin-contact-form/src/index.ts"],
      "@vivd/plugin-contact-form/*": ["../plugin-contact-form/src/*"],
      "@vivd/plugin-newsletter": ["./src/index.ts"],
      "@vivd/plugin-newsletter/*": ["./src/*"],
      "@vivd/shared": ["../shared/src/index.ts"],
      "@vivd/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src"]
}
