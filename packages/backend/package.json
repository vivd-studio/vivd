{
  "name": "@vivd/backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Vivd - AI-powered website builder",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsup",
    "typecheck": "tsc --project tsconfig.typecheck.json --noEmit --pretty false",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --exclude test/integration/**",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:prod": "node dist/db/migrate.js",
    "migrate:versions": "tsx src/scripts/migrate-to-versions.ts",
    "migrate:tenants": "tsx src/scripts/migrate-to-tenant-layout.ts",
    "migrate:project-meta": "tsx src/scripts/migrate-project-metadata-to-db.ts",
    "cli": "tsx src/generator/cli.ts"
  },
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.983.0",
    "@aws-sdk/client-sesv2": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.985.0",
    "@openrouter/sdk": "^0.2.9",
    "@trpc/server": "^11.7.2",
    "@types/archiver": "^7.0.0",
    "@types/nodemailer": "^7.0.11",
    "@vivd/builder": "1.0.0",
    "@vivd/shared": "1.0.0",
    "archiver": "^7.0.1",
    "axios": "^1.13.2",
    "better-auth": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.0",
    "execa": "^9.6.1",
    "express": "^5.2.1",
    "extract-zip": "^2.0.1",
    "http-proxy-middleware": "^3.0.5",
    "ignore": "^7.0.5",
    "image-size": "^2.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.3",
    "openai": "^6.10.0",
    "parse5": "^8.0.0",
    "pg": "^8.16.3",
    "resend": "^6.9.2",
    "sharp": "^0.34.5",
    "tree-kill": "^1.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/image-size": "^0.8.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.2",
    "@types/pg": "^8.15.6",
    "@types/sharp": "^0.32.0",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.8",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
