---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = "your-title",
  description = "your-description",
  lang = "en",
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {description ? <meta name="description" content={description} /> : null}
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
