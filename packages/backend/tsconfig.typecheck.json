{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "rootDir": "..",
    "paths": {
      "@vivd/backend/*": ["./*"],
      "@vivd/plugin-analytics/*": ["../plugin-analytics/src/*"],
      "@vivd/plugin-contact-form/*": ["../plugin-contact-form/src/*"],
      "@vivd/plugin-newsletter/*": ["../plugin-newsletter/src/*"],
      "@vivd/plugin-table-booking/*": ["../plugin-table-booking/src/*"],
      "@vivd/plugin-sdk": ["../plugin-sdk/src/index.ts"],
      "@vivd/shared": ["../shared/src/index.ts"],
      "@vivd/shared/*": ["../shared/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "../shared/src/**/*",
    "../plugin-contact-form/src/backend/**/*",
    "../plugin-newsletter/src/backend/**/*",
    "../plugin-table-booking/src/backend/**/*"
  ],
  "exclude": ["node_modules", "**/*.spec.ts", "test", "projects", "dist"]
}
