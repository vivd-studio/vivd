{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "rootDir": "..",
    "paths": {
      "@vivd/backend/*": ["./*"],
      "@vivd/plugin-analytics/*": ["../../plugins/native/analytics/src/*"],
      "@vivd/plugin-contact-form/*": ["../../plugins/native/contact-form/src/*"],
      "@vivd/plugin-newsletter/*": ["../../plugins/native/newsletter/src/*"],
      "@vivd/plugin-table-booking/*": ["../../plugins/native/table-booking/src/*"],
      "@vivd/plugin-sdk": ["../../plugins/sdk/src/index.ts"],
      "@vivd/shared": ["../shared/src/index.ts"],
      "@vivd/shared/*": ["../shared/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "../shared/src/**/*",
    "../../plugins/native/contact-form/src/backend/**/*",
    "../../plugins/native/newsletter/src/backend/**/*",
    "../../plugins/native/table-booking/src/backend/**/*"
  ],
  "exclude": ["node_modules", "**/*.spec.ts", "test", "projects", "dist"]
}
