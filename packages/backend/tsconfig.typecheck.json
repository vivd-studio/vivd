{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "rootDir": "..",
    "paths": {
      "@vivd/builder": ["../builder/src/index.ts"],
      "@vivd/builder/*": ["../builder/src/*"],
      "@vivd/shared": ["../shared/src/index.ts"],
      "@vivd/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*", "../builder/src/**/*", "../shared/src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts", "test", "projects", "dist"]
}
