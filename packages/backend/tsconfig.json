{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "es2020",
    "lib": ["es2018", "dom"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@vivd/backend/*": ["./*"],
      "@vivd/plugin-analytics/*": ["../plugin-analytics/src/*"],
      "@vivd/plugin-contact-form/*": ["../plugin-contact-form/src/*"],
      "@vivd/plugin-newsletter/*": ["../plugin-newsletter/src/*"],
      "@vivd/plugin-table-booking/*": ["../plugin-table-booking/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts", "test", "projects"]
}
