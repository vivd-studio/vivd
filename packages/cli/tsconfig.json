{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "types": ["node"],
    "paths": {
      "@vivd/plugin-analytics/*": ["../../plugins/native/analytics/src/*"],
      "@vivd/plugin-contact-form/*": ["../../plugins/native/contact-form/src/*"],
      "@vivd/plugin-newsletter/*": ["../../plugins/native/newsletter/src/*"],
      "@vivd/plugin-table-booking/*": ["../../plugins/native/table-booking/src/*"],
      "@vivd/plugin-sdk": ["../../plugins/sdk/src/index.ts"],
      "@vivd/plugin-sdk/*": ["../../plugins/sdk/src/*"],
      "@vivd/shared": ["../shared/src/index.ts"],
      "@vivd/shared/*": ["../shared/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../shared/src/**/*.ts",
    "../../plugins/native/analytics/src/cli/**/*.ts",
    "../../plugins/native/contact-form/src/cli/**/*.ts",
    "../../plugins/native/newsletter/src/cli/**/*.ts",
    "../../plugins/native/table-booking/src/cli/**/*.ts"
  ]
}
