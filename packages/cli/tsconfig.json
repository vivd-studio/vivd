{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "types": ["node"],
    "paths": {
      "@vivd/plugin-analytics/*": ["../plugin-analytics/src/*"],
      "@vivd/plugin-contact-form/*": ["../plugin-contact-form/src/*"],
      "@vivd/plugin-newsletter/*": ["../plugin-newsletter/src/*"],
      "@vivd/plugin-sdk": ["../plugin-sdk/src/index.ts"],
      "@vivd/shared": ["../shared/src/index.ts"],
      "@vivd/shared/*": ["../shared/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../shared/src/**/*.ts",
    "../plugin-analytics/src/cli/**/*.ts",
    "../plugin-contact-form/src/cli/**/*.ts",
    "../plugin-newsletter/src/cli/**/*.ts"
  ]
}
