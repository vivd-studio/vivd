{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "../..",
    "paths": {
      "@studio/*": ["./server/*"],
      "@studio/shared/*": ["./shared/*"],
      "@vivd/installed-plugins": ["../../plugins/installed/src/index.ts"],
      "@vivd/installed-plugins/*": ["../../plugins/installed/src/*"],
      "@vivd/plugin-table-booking": ["../../plugins/native/table-booking/src/index.ts"],
      "@vivd/plugin-table-booking/*": ["../../plugins/native/table-booking/src/*"],
      "@vivd/plugin-sdk": ["../../plugins/sdk/src/index.ts"],
      "@vivd/plugin-sdk/*": ["../../plugins/sdk/src/*"],
      "@vivd/shared": ["../shared/src/index.ts"],
      "@vivd/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["server/**/*", "shared/**/*", "../shared/src/**/*"],
  "exclude": ["node_modules", "dist", "client"]
}
