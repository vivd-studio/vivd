{
  "name": "@vivd/studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Vivd Studio - Standalone editing environment",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsup server/index.ts --format esm --outDir dist --dts",
    "build:client": "vite build --config client/vite.config.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@trpc/server": "^11.7.2",
    "@tanstack/react-query": "^5.90.12",
    "@trpc/client": "^11.7.2",
    "@trpc/react-query": "^11.7.2",
    "@vivd/theme": "1.0.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "fs-extra": "^11.2.0",
    "http-proxy-middleware": "^3.0.5",
    "lucide-react": "^0.556.0",
    "parse5": "^8.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "simple-git": "^3.27.0",
    "tree-kill": "^1.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.22",
    "concurrently": "^8.2.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^3.2.4"
  }
}
