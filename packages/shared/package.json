{
  "name": "@vivd/shared",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./studio": {
      "import": "./dist/studio/index.js",
      "types": "./dist/studio/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty false",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3"
  }
}
