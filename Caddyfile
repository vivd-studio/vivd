# Vivd Caddy Configuration
# Serves published sites and proxies to backend for studio routes

{
    # Disable automatic HTTPS since TLS is terminated by external load balancer
    auto_https off
    
    # Enable admin API for dynamic config reloads
    # Binds to all interfaces within container, but port 2019 is NOT exposed
    # externally (only ports 80/443 are in docker-compose), so this is safe.
    # Only containers on vivd-network can access it.
    admin 0.0.0.0:2019 {
        origins http://caddy:2019 http://backend:3000 http://localhost:2019 http://127.0.0.1:2019
    }
}

(vivd_platform_routes) {
    handle /plugins/* {
        reverse_proxy backend:3000
    }

    handle /email/v1/feedback/* {
        reverse_proxy backend:3000
    }

    handle /vivd-studio/api/* {
        reverse_proxy backend:3000
    }

    handle /vivd-studio* {
        reverse_proxy frontend:80
    }

    import /etc/caddy/runtime.d/*.caddy
}

(vivd_public_fallback) {
    handle /health {
        respond "OK" 200
    }

    handle {
        root * /srv/published
        try_files {path} {path}/index.html =404
        file_server
    }

    handle_errors {
        @404 expression {err.status_code} == 404
        handle @404 {
            root * /srv/default
            rewrite * /default-404.html
            file_server
        }
    }
}

# Import all dynamically-generated site configs
import /etc/caddy/sites.d/*.caddy

# Public docs host
http://{$VIVD_DOCS_HOST:docs.vivd.studio} {
    handle /health {
        respond "OK" 200
    }

    handle {
        reverse_proxy docs:80
    }
}

# Public plugin API host – use http:// because TLS is terminated by Traefik,
# so Caddy receives these requests on port 80.
http://{$VIVD_PUBLIC_PLUGIN_API_HOST:api.vivd.studio}, http://api.localhost {
    handle /plugins/* {
        reverse_proxy backend:3000
    }

    handle /health {
        respond "OK" 200
    }

    handle {
        respond "Not found" 404
    }
}

# Default server - handles studio routes and fallback
# Only listen on :80 - TLS is handled by external load balancer
:80 {
    import vivd_platform_routes
    import vivd_public_fallback
}
