# Control Panel Environment
# Copy to .env and fill in values

# Database
POSTGRES_USER=control_panel
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=control_panel

# Control Panel Auth
BETTER_AUTH_SECRET=changeme_32_char_minimum_secret_here
BETTER_AUTH_URL=https://control.vivd.studio

# Dokploy Connection
DOKPLOY_URL=https://your-dokploy.example.com
DOKPLOY_API_KEY=your_dokploy_api_key_here
# Dokploy compose mode: use "stack" for raw compose (UI: "raw")
# DOKPLOY_COMPOSE_TYPE=stack

# Shared API Keys (used for all instances by default)
SHARED_OPENROUTER_API_KEY=sk-or-v1-...
SHARED_GOOGLE_API_KEY=AIza...
SHARED_GITHUB_TOKEN=ghp_...
SHARED_GITHUB_ORG=vivd-studio
SHARED_OPENCODE_MODEL=google/gemini-3-flash-preview

# Default Scraper
DEFAULT_SCRAPER_URL=https://scraper.vivd.studio
DEFAULT_SCRAPER_API_KEY=your_scraper_api_key
