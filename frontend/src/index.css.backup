@import "tailwindcss";
@config "../tailwind.config.js";

@layer base {
  :root {
    --radius: 0.5rem;

    /* Natural Light Theme - Pristine & Clean */
    --background: 40 33% 98%; /* Warm off-white */
    --foreground: 20 25% 18%; /* Warm dark brown (#583828 adjusted) */

    --card: 40 25% 99%; /* Slightly warmer white */
    --card-foreground: 20 25% 18%;

    --popover: 40 33% 99%;
    --popover-foreground: 20 25% 18%;

    /* Primary: Fresh Sage Green (lighter & sharper) */
    --primary: 153 42% 52%;
    --primary-foreground: 40 33% 98%;

    /* Secondary: Soft cream (#fadb90 lightened) */
    --secondary: 43 60% 94%;
    --secondary-foreground: 20 25% 22%;

    /* Muted: Very light warm gray */
    --muted: 40 20% 94%;
    --muted-foreground: 20 10% 50%;

    /* Accent: Warm coral/orange (#f38560) */
    --accent: 16 86% 66%;
    --accent-foreground: 40 33% 98%;

    --destructive: 0 72% 51%;
    --destructive-foreground: 0 0% 100%;

    --border: 40 15% 88%;
    --input: 40 15% 88%;
    --ring: 153 42% 52%; /* Matches primary */

    /* Charts using the natural palette */
    --chart-1: 153 42% 52%; /* Fresh sage green */
    --chart-2: 16 86% 66%; /* Coral orange */
    --chart-3: 184 48% 24%; /* Deep teal */
    --chart-4: 43 75% 77%; /* Soft yellow */
    --chart-5: 193 24% 76%; /* Soft blue-gray */
  }

  .dark {
    /* Natural Dark Theme - Warm & Earthy */
    --background: 20 20% 8%; /* Warm charcoal */
    --foreground: 40 20% 92%; /* Warm off-white */

    --card: 20 18% 11%; /* Slightly lighter warm dark */
    --card-foreground: 40 20% 92%;

    --popover: 20 18% 10%;
    --popover-foreground: 40 20% 92%;

    /* Primary: Fresh Sage Green (lighter & sharper) */
    --primary: 153 50% 60%;
    --primary-foreground: 20 20% 8%;

    /* Secondary: Muted warm tones */
    --secondary: 20 15% 16%;
    --secondary-foreground: 40 20% 92%;

    /* Muted: Warm dark gray */
    --muted: 20 12% 16%;
    --muted-foreground: 40 12% 60%;

    /* Accent: Warm coral/orange */
    --accent: 16 70% 58%;
    --accent-foreground: 20 20% 8%;

    --destructive: 0 62% 45%;
    --destructive-foreground: 0 0% 100%;

    --border: 20 12% 20%;
    --input: 20 12% 20%;
    --ring: 153 50% 60%;

    /* Charts in dark mode */
    --chart-1: 153 50% 60%;
    --chart-2: 16 75% 60%;
    --chart-3: 184 40% 40%;
    --chart-4: 43 65% 65%;
    --chart-5: 193 30% 65%;
  }
}

@layer base {
  * {
    @apply border-border;
  }

  body {
    @apply bg-background text-foreground;
  }

  /* Fix autofill background in dark mode */
  input:-webkit-autofill,
  input:-webkit-autofill:hover,
  input:-webkit-autofill:focus,
  input:-webkit-autofill:active {
    -webkit-box-shadow: 0 0 0 30px hsl(var(--card)) inset !important;
    -webkit-text-fill-color: hsl(var(--foreground)) !important;
    caret-color: hsl(var(--foreground)) !important;
  }

  /* Give inputs a visible background */
  input:not([type="checkbox"]):not([type="radio"]),
  textarea,
  select {
    background-color: hsl(var(--card)) !important;
  }
}

@keyframes bop {
  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-10px);
  }
}

@keyframes pulse-outline {
  0% {
    box-shadow: 0 0 0 0 hsla(153, 28%, 49%, 0.6);
  }

  70% {
    box-shadow: 0 0 0 10px hsla(153, 28%, 49%, 0);
  }

  100% {
    box-shadow: 0 0 0 0 hsla(153, 28%, 49%, 0);
  }
}

.animate-bop {
  animation: bop 3s ease-in-out infinite;
}

.animate-pulse-outline {
  animation: pulse-outline 2s infinite;
}
