# Vivd Caddy Configuration - Development
# Serves published sites and proxies to backend for studio routes

{
    # Keep local development plain HTTP to avoid mixed-content and local cert issues.
    auto_https off

    # Enable admin API for dynamic config reloads
    # Binds to all interfaces within container, but port 2019 is NOT exposed
    # externally (only ports 80/443 are in docker-compose), so this is safe.
    # Only containers on vivd-network can access it.
    admin 0.0.0.0:2019 {
        origins http://caddy:2019 http://backend:3000 http://localhost:2019 http://127.0.0.1:2019
    }
}

# Import all dynamically-generated site configs
import /etc/caddy/sites.d/*.caddy

# Public docs host (HTTP in local dev)
http://{$VIVD_DOCS_HOST:docs.localhost} {
    handle /health {
        respond "OK" 200
    }

    handle {
        reverse_proxy docs:4321
    }
}

# Public plugin API host (HTTP in local dev)
http://api.localhost {
    handle /plugins/* {
        reverse_proxy backend:3000
    }

    handle /health {
        respond "OK" 200
    }

    handle {
        respond "Not found" 404
    }
}

# Default server - handles studio routes and fallback
:80 {
    # Vivd Studio API routes - proxy to backend
    handle /vivd-studio/api/* {
        reverse_proxy backend:3000
    }

    # Vivd Studio frontend (main app) - proxy to Vite dev server
    handle /vivd-studio* {
        reverse_proxy frontend:5173
    }

    # Active studio runtime routes
    import /etc/caddy/runtime.d/*.caddy

    # Health check endpoint
    handle /health {
        respond "OK" 200
    }

    # Default: try to serve published site or return 404
    handle {
        root * /srv/published
        try_files {path} {path}/index.html =404
        file_server
    }

    # Global 404 handler for the fallback server
    handle_errors {
        @404 expression {err.status_code} == 404
        handle @404 {
            root * /srv/default
            rewrite * /default-404.html
            file_server
        }
    }
}
