OPENROUTER_API_KEY=sk-or-v1-...
DATABASE_URL=postgresql://postgres:password@postgres:5432/landing_agent
BETTER_AUTH_SECRET=changeme
BETTER_AUTH_URL=http://localhost:3000
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=landing_agent

# Scraper service authentication (used by backend to call scraper)
SCRAPER_API_KEY=your-secure-api-key-here

# Studio Machine Storage (S3/R2)
# Studio machines hydrate project files from object storage into a local workspace directory
# and periodically sync changes back (see `packages/studio/entrypoint.sh`).
# Local provider (`STUDIO_MACHINE_PROVIDER=local`) uses the same variables for local
# hydrate/sync without requiring the studio container entrypoint.
#
# You can use Cloudflare R2 via S3-compatible credentials:
# R2_BUCKET=my-platform-bucket
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# R2_ACCESS_KEY=xxx
# R2_SECRET_KEY=yyy
#
# Optional (overrides how the entrypoint computes the bucket path):
# VIVD_S3_BUCKET=my-platform-bucket              # defaults to R2_BUCKET
# VIVD_S3_ENDPOINT_URL=https://...               # defaults to R2_ENDPOINT
# VIVD_S3_PREFIX=tenants/default/projects/my-project/v1
# VIVD_S3_SOURCE_URI=s3://my-platform-bucket/tenants/default/projects/my-project/v1/source
# VIVD_S3_OPENCODE_PREFIX=tenants/default/projects/my-project/opencode
# VIVD_S3_OPENCODE_URI=s3://my-platform-bucket/tenants/default/projects/my-project/opencode
# VIVD_S3_SYNC_INTERVAL_SECONDS=30
# VIVD_WORKSPACE_DIR=/home/studio/project        # default inside studio machines
# VIVD_OPENCODE_DATA_HOME=/home/studio/opencode-data
# # OpenCode sessions are stored in $XDG_DATA_HOME/opencode/storage
# # and are synced via VIVD_S3_OPENCODE_{PREFIX,URI}, separate from source code.

# Single Project Mode (for single-project licenses)
# When true, the app operates with a single project and bypasses the project list
SINGLE_PROJECT_MODE=false

# Usage Limits (optional - defaults shown)
# Controls instance-wide cost and image generation limits
# LICENSE_DAILY_COST_LIMIT=20
# LICENSE_WEEKLY_COST_LIMIT=50
# LICENSE_MONTHLY_COST_LIMIT=100
# LICENSE_IMAGE_GEN_PER_MONTH=50
# LICENSE_WARNING_THRESHOLD=0.8

# SaaS Mode (optional - for managed deployments)
# When SAAS_MODE=true, authentication and limits are fetched from control plane
# SAAS_MODE=false
# CONTROL_PLANE_URL=https://vivd.studio
# CONTROL_PLANE_SECRET=xxx
# TENANT_ID=org_xxx

# Project storage (filesystem tenant prep)
# New projects are stored under: projects/tenants/<PROJECTS_TENANT_ID>/<slug>/v<version>/
# Legacy projects at projects/<slug>/v<version>/ are still supported.
# PROJECTS_TENANT_ID=default

# GitHub sync (optional backup)
# Pushes the local project repo state to a GitHub org repo on publish/save.
# Repo name pattern: <GITHUB_REPO_PREFIX><tenantId>-<slug>-v<version>
# GITHUB_SYNC_ENABLED=false
# GITHUB_SYNC_STRICT=false          # If true, failures throw (best-effort is recommended)
# GITHUB_ORG=your-github-org
# GITHUB_TOKEN=ghp_xxx
# GITHUB_REPO_PREFIX=vivd-
# GITHUB_REPO_VISIBILITY=private    # private | public | internal
# GITHUB_API_URL=https://api.github.com
# GITHUB_GIT_HOST=github.com

# Studio Machines Provider
# - local: spawns @vivd/studio as a child process inside the backend container
# - fly: provisions isolated Fly.io Machines (local-first testing supported)
# STUDIO_MACHINE_PROVIDER=local

# Fly.io Studio Machines (when STUDIO_MACHINE_PROVIDER=fly)
# Important: The studio machine must be able to reach the backend URL for usage reporting.
# For local-first testing, expose your local Caddy (port 80) via a tunnel and set BACKEND_URL to it.
# BACKEND_URL=https://your-tunnel.example
#
# FLY_API_TOKEN=fly_xxx
# FLY_STUDIO_APP=vivd-studio-dev
# FLY_STUDIO_IMAGE=ghcr.io/vivd-studio/vivd-studio:latest
# FLY_STUDIO_REGION=iad
# FLY_STUDIO_PORT_START=3100
# FLY_STUDIO_PUBLIC_HOST=vivd-studio-dev.fly.dev
# FLY_STUDIO_PUBLIC_PROTOCOL=https
# FLY_STUDIO_ENV_PASSTHROUGH=GOOGLE_API_KEY,OPENROUTER_API_KEY,OPENCODE_MODEL,OPENCODE_MODELS
