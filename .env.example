OPENROUTER_API_KEY=sk-or-v1-...
# OpenCode (studio) can use Vertex AI instead of OpenRouter.
# Only GOOGLE_CLOUD_PROJECT is required for provider selection.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# VERTEX_LOCATION=global
# Optional: paste the full service-account JSON as one line.
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}
# Optional override for where the file is written automatically:
# VIVD_GOOGLE_APPLICATION_CREDENTIALS_PATH=/tmp/vivd-google-application-credentials.json
DATABASE_URL=postgresql://postgres:password@postgres:5432/landing_agent
BETTER_AUTH_SECRET=changeme
BETTER_AUTH_URL=http://app.localhost
BACKEND_URL=http://127.0.0.1:3000

# Host-based tenant routing
# Local parity recommendation (no external DNS required):
# - Control plane: app.localhost
# - Tenant hosts: {org}.localhost
# Alternative (requires public DNS resolution): app.127.0.0.1.nip.io + {org}.127.0.0.1.nip.io
DOMAIN=http://localhost
TENANT_DOMAIN_ROUTING_ENABLED=true
CONTROL_PLANE_HOST=app.localhost
TENANT_BASE_DOMAIN=localhost
SUPERADMIN_HOSTS=app.localhost,localhost,127.0.0.1
TRUSTED_DOMAINS=app.localhost,localhost,127.0.0.1

# Public plugin runtime URL base (used in generated contact-form snippets)
# Local dev: http://api.localhost
# Staging/prod: https://api.vivd.studio (or your own API host)
# VIVD_PUBLIC_PLUGIN_API_BASE_URL=https://api.vivd.studio

# Contact form email delivery (provider abstraction)
# Auto-detects SES when VIVD_SES_FROM_EMAIL is set.
# Optional override:
# VIVD_EMAIL_PROVIDER=ses                 # ses | noop
# Legacy alias still supported: EMAIL_PROVIDER
# VIVD_SES_REGION=eu-central-1
# VIVD_SES_ACCESS_KEY_ID=...
# VIVD_SES_SECRET_ACCESS_KEY=...
# VIVD_SES_FROM_EMAIL=noreply@mail.vivd.studio

# Contact form submission retention
# Set to 0 to disable automatic deletion.
# VIVD_CONTACT_FORM_RETENTION_DAYS=30
# VIVD_CONTACT_FORM_RETENTION_CLEANUP_INTERVAL_MS=21600000

# Contact form anti-abuse controls (optional; defaults shown)
# Keep human retries possible while blocking rapid-fire or duplicate spam.
# Set any value to 0 to disable that specific guard.
# VIVD_CONTACT_FORM_MIN_REPEAT_SECONDS=2
# VIVD_CONTACT_FORM_RATE_LIMIT_PER_IP_PER_MINUTE=10
# VIVD_CONTACT_FORM_RATE_LIMIT_PER_IP_PER_HOUR=120
# VIVD_CONTACT_FORM_RATE_LIMIT_PER_TOKEN_PER_MINUTE=60
# VIVD_CONTACT_FORM_RATE_LIMIT_PER_TOKEN_PER_HOUR=1000
# VIVD_CONTACT_FORM_DUPLICATE_WINDOW_SECONDS=45
# VIVD_CONTACT_FORM_MAX_TOTAL_FIELD_CHARS=8000
# VIVD_CONTACT_FORM_MAX_SINGLE_FIELD_CHARS=2000
# VIVD_CONTACT_FORM_MAX_LINKS_PER_SUBMISSION=5

# Contact form Turnstile automation (optional, needed when enabling Turnstile per project in Super Admin)
# VIVD_TURNSTILE_AUTOMATION_ENABLED=true
# VIVD_TURNSTILE_CLOUDFLARE_ACCOUNT_ID=...
# VIVD_TURNSTILE_CLOUDFLARE_API_TOKEN=...
# VIVD_TURNSTILE_WIDGET_NAME_PREFIX=vivd-contact-form
# VIVD_TURNSTILE_WIDGET_MODE=managed  # managed | non-interactive | invisible
# VIVD_TURNSTILE_MAX_DOMAINS_PER_WIDGET=10
# VIVD_TURNSTILE_VERIFY_TIMEOUT_MS=6000
# VIVD_TURNSTILE_SYNC_INTERVAL_MS=900000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=landing_agent

# Scraper service authentication (used by backend to call scraper)
SCRAPER_API_KEY=your-secure-api-key-here

# Studio Machine Storage (S3/R2)
# Studio machines hydrate project files from object storage into a local workspace directory
# and periodically sync changes back (see `packages/studio/entrypoint.sh`).
# Local provider (`STUDIO_MACHINE_PROVIDER=local`) uses the same variables for local
# hydrate/sync without requiring the studio container entrypoint.
#
# You can use Cloudflare R2 via S3-compatible credentials:
# R2_BUCKET=my-platform-bucket
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# R2_ACCESS_KEY=xxx
# R2_SECRET_KEY=yyy
#
# Optional (overrides how the entrypoint computes the bucket path):
# VIVD_S3_BUCKET=my-platform-bucket              # defaults to R2_BUCKET
# VIVD_S3_ENDPOINT_URL=https://...               # defaults to R2_ENDPOINT
# VIVD_S3_PREFIX=tenants/default/projects/my-project/v1
# VIVD_S3_SOURCE_URI=s3://my-platform-bucket/tenants/default/projects/my-project/v1/source
# VIVD_S3_OPENCODE_PREFIX=tenants/default/projects/my-project/opencode
# VIVD_S3_OPENCODE_URI=s3://my-platform-bucket/tenants/default/projects/my-project/opencode
# VIVD_S3_SYNC_INTERVAL_SECONDS=30
# VIVD_WORKSPACE_DIR=/home/studio/project        # default inside studio machines
# VIVD_OPENCODE_DATA_HOME=/home/studio/opencode-data
# VIVD_PACKAGE_CACHE_DIR=/home/studio/opencode-data/package-cache
# DEVSERVER_INSTALL_TIMEOUT_MS=900000            # 15m install timeout for large Astro deps
# DEVSERVER_NODE_MODULES_CACHE=1                 # cache node_modules archive per lockfile
# VIVD_SYNC_PAUSE_FILE=/tmp/vivd-sync.pause      # studio sets while installing deps to pause S3 sync
# VIVD_SYNC_PAUSE_MAX_AGE_SECONDS=600
# STUDIO_HOST=0.0.0.0                            # explicit bind host for studio HTTP server
# # Studio access control (optional)
# # When set, @vivd/studio requires a token for tRPC + file/upload endpoints.
# # Fly studio machines get a per-machine token automatically; local provider leaves this unset by default.
# # STUDIO_ACCESS_TOKEN=changeme
# # OpenCode sessions are stored in $XDG_DATA_HOME/opencode/storage
# # and are synced via VIVD_S3_OPENCODE_{PREFIX,URI}, separate from source code.

# Single Project Mode (for single-project licenses)
# When true, the app operates with a single project and bypasses the project list
SINGLE_PROJECT_MODE=false

# Usage Limits (optional - defaults shown)
# Controls instance-wide cost and image generation limits
# LICENSE_DAILY_COST_LIMIT=20
# LICENSE_WEEKLY_COST_LIMIT=50
# LICENSE_MONTHLY_COST_LIMIT=100
# LICENSE_IMAGE_GEN_PER_MONTH=50
# LICENSE_WARNING_THRESHOLD=0.8

# Upload Limits (optional)
# ZIP_IMPORT_MAX_FILE_SIZE_MB=250

# SaaS Mode (optional - for managed deployments)
# When SAAS_MODE=true, authentication and limits are fetched from control plane
# SAAS_MODE=false
# CONTROL_PLANE_URL=https://vivd.studio
# CONTROL_PLANE_SECRET=xxx
# TENANT_ID=org_xxx

# Project storage (filesystem tenant prep)
# New projects are stored under: projects/tenants/<PROJECTS_TENANT_ID>/<slug>/v<version>/
# Legacy projects at projects/<slug>/v<version>/ are still supported.
# PROJECTS_TENANT_ID=default

# GitHub sync (optional backup)
# Pushes the local project repo state to a GitHub org repo on publish/save.
# Repo name pattern: <GITHUB_REPO_PREFIX><tenantId>-<slug>-v<version>
# GITHUB_SYNC_ENABLED=false
# GITHUB_SYNC_STRICT=false          # If true, failures throw (best-effort is recommended)
# GITHUB_ORG=your-github-org
# GITHUB_TOKEN=ghp_xxx
# GITHUB_REPO_PREFIX=dev-           # Optional; e.g. dev-, staging-
# GITHUB_REPO_VISIBILITY=private    # private | public | internal
# GITHUB_API_URL=https://api.github.com
# GITHUB_GIT_HOST=github.com

# Studio Machines Provider
# - local: spawns @vivd/studio as a child process inside the backend container
# - fly: provisions isolated Fly.io Machines (local-first testing supported)
# STUDIO_MACHINE_PROVIDER=local

# Fly.io Studio Machines (when STUDIO_MACHINE_PROVIDER=fly)
# Important: The studio machine must be able to reach the backend URL for usage reporting.
# For local-first testing, expose your local Caddy (port 80) via a tunnel and set BACKEND_URL to it.
# BACKEND_URL=https://your-tunnel.example
#
# FLY_API_TOKEN=fly_xxx
# FLY_STUDIO_APP=vivd-studio-dev
# Studio image selection:
# - default: auto-picks latest semver tag from ghcr.io/vivd-studio/vivd-studio
# - optional override: change auto source repository
# FLY_STUDIO_IMAGE_REPO=ghcr.io/vivd-studio/vivd-studio
# - optional override: pin image explicitly with FLY_STUDIO_IMAGE
# FLY_STUDIO_IMAGE=ghcr.io/vivd-studio/vivd-studio:0.2.2
# Note: Fly machine region is immutable; changing FLY_STUDIO_REGION requires destroying/recreating existing studio machines.
# FLY_STUDIO_REGION=fra
# FLY_STUDIO_PORT_START=3100
# FLY_STUDIO_PUBLIC_HOST=vivd-studio-dev.fly.dev
# FLY_STUDIO_PUBLIC_PROTOCOL=https
# FLY_STUDIO_CPU_KIND=shared                  # shared | performance
# FLY_STUDIO_CPUS=1
# FLY_STUDIO_MEMORY_MB=1024                   # performance mode auto-clamped to Fly minimums (>=4096)
# Backend keepalive timeout (explicitly suspend/stop studio after no frontend heartbeat)
# FLY_STUDIO_IDLE_TIMEOUT_MS=600000
# FLY_STUDIO_IDLE_CHECK_INTERVAL_MS=30000
# FLY_STUDIO_ENV_PASSTHROUGH=GOOGLE_API_KEY,OPENROUTER_API_KEY,GOOGLE_CLOUD_PROJECT,VERTEX_LOCATION,GOOGLE_APPLICATION_CREDENTIALS,GOOGLE_APPLICATION_CREDENTIALS_JSON,VIVD_GOOGLE_APPLICATION_CREDENTIALS_PATH,OPENCODE_MODEL,OPENCODE_MODELS
