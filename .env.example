OPENROUTER_API_KEY=sk-or-v1-...
# The hosted self-host installer writes the usual secrets and defaults for you:
# auth secret, Postgres credentials, scraper key, local bucket credentials,
# OPENCODE_MODEL_STANDARD, and OPENCODE_MODEL_ADVANCED.
# Self-hosting currently uses OpenRouter for OpenCode model access so one API key
# can cover multiple model tiers. Direct multi-provider self-host config can come later.
# Optional image-generation timeouts (milliseconds)
# VIVD_OPENROUTER_IMAGE_TIMEOUT_MS=900000
# VIVD_IMAGE_AI_DOWNLOAD_TIMEOUT_MS=600000
# Experimental CLI preview screenshot command. Disabled by default so the command stays hidden
# until we intentionally expose it.
# VIVD_CLI_PREVIEW_SCREENSHOT_ENABLED=false
# Optional Studio release-smoke tuning (milliseconds)
# Keep container boot generous, but let prompt round-trips fail faster than the full smoke budget.
# VIVD_STUDIO_SMOKE_TIMEOUT_MS=300000
# VIVD_STUDIO_SMOKE_ROUND_TRIP_TIMEOUT_MS=90000
# OpenCode (studio) can use Vertex AI instead of OpenRouter.
# Only GOOGLE_CLOUD_PROJECT is required for provider selection.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# VERTEX_LOCATION=global
# Optional: paste the full service-account JSON as one line.
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}
# Optional override for where the file is written automatically:
# VIVD_GOOGLE_APPLICATION_CREDENTIALS_PATH=/tmp/vivd-google-application-credentials.json
# Scratch project creation mode:
# - studio_astro: default; backend prepares an Astro starter and Studio/OpenCode creates the first draft
# - legacy_html: compatibility mode; backend generates plain HTML directly
VIVD_SCRATCH_CREATION_MODE=studio_astro
# Optional scratch-generation model overrides.
# Defaults:
# VIVD_GENERATION_MODEL=google/gemini-3.1-pro-preview
# VIVD_ANALYSIS_MODEL=google/gemini-3.1-pro-preview
# VIVD_HERO_GENERATION_MODEL=google/gemini-3-pro-image-preview
# VIVD_IMAGE_EDITING_MODEL=google/gemini-3-pro-image-preview
DATABASE_URL=postgresql://postgres:password@postgres:5432/landing_agent
BETTER_AUTH_SECRET=changeme
BACKEND_URL=http://127.0.0.1:3000

# Install profile bootstrap
# - solo: default one-host self-hosting with /vivd-studio and same-host /plugins/*
# - platform: current SaaS-style multi-org + host-based admin/domain model
# New installs now default to solo when unset. Set this explicitly in SaaS/platform environments.
# VIVD_INSTALL_PROFILE=platform
# Optional JSON bootstrap overrides. Vivd persists runtime edits in system settings after boot.
# VIVD_INSTANCE_CAPABILITY_POLICY={"multiOrg":false,"tenantHosts":false,"customDomains":false,"orgLimitOverrides":false,"orgPluginEntitlements":false,"projectPluginEntitlements":false,"dedicatedPluginHost":false}
# VIVD_INSTANCE_PLUGIN_DEFAULTS={"contact_form":{"enabled":true},"analytics":{"enabled":true}}
# VIVD_INSTANCE_LIMIT_DEFAULTS={"dailyCreditLimit":1000,"weeklyCreditLimit":2500,"monthlyCreditLimit":5000,"imageGenPerMonth":25,"warningThreshold":0.8,"maxProjects":1}

# Primary host / routing
# Solo default:
# - set only DOMAIN as the bootstrap public origin
# - Studio: http://localhost/vivd-studio
# - Plugins: http://localhost/plugins/*
# Platform example:
# - set VIVD_INSTALL_PROFILE=platform
# - set CONTROL_PLANE_HOST=app.localhost
# - set TENANT_BASE_DOMAIN=localhost
DOMAIN=http://localhost
TENANT_DOMAIN_ROUTING_ENABLED=false
TENANT_BASE_DOMAIN=
# Optional explicit auth/public origin override.
# In solo, auth now falls back to DOMAIN automatically.
# If unset, self-host installs can later manage the main public host in Instance Settings.
# VIVD_APP_URL=https://yourdomain.com
# Legacy override still supported:
# BETTER_AUTH_URL=https://yourdomain.com
# Optional host override when the admin/control plane runs on a different host.
# CONTROL_PLANE_HOST=app.localhost
# Optional extras when you want more than the main DOMAIN trusted/allowed.
# SUPERADMIN_HOSTS=app.localhost,default.localhost
# TRUSTED_DOMAINS=preview.localhost
# Self-host Caddy TLS mode:
# - managed: bundled Caddy owns HTTPS certificates directly (recommended on a VPS with a real hostname)
# - off: Caddy serves plain HTTP only (useful for localhost, raw IPs, or when Dockploy/Traefik terminates TLS upstream)
# The hosted self-host installer picks this automatically: managed for public hostnames, off for localhost/raw IP installs.
# VIVD_CADDY_TLS_MODE=off
# VIVD_CADDY_PRIMARY_HOST=localhost
# VIVD_CADDY_ACME_EMAIL=admin@example.com
# VIVD_PUBLISH_INCLUDE_WWW_ALIAS=false
# Public docs host
VIVD_DOCS_HOST=docs.localhost
# Canonical docs site URL used when building the public docs workspace.
# Production example: https://docs.vivd.studio
VIVD_DOCS_SITE_URL=http://docs.localhost
# Optional override for where app "Docs" links should point.
# Useful for self-host installs that do not run the docs service locally.
# VIVD_PUBLIC_DOCS_BASE_URL=https://docs.vivd.studio

# Public plugin runtime URL base (used in generated plugin snippets, e.g. contact-form + analytics)
# Local dev: http://api.localhost
# Staging/prod: https://api.vivd.studio (or your own API host)
# Solo same-host installs can leave this unset; Vivd will generate current-host /plugins/* URLs.
# VIVD_PUBLIC_PLUGIN_API_BASE_URL=https://api.vivd.studio

# Contact form email delivery (provider abstraction)
# Auto-detects providers in this order when VIVD_EMAIL_PROVIDER is unset:
# Resend -> SES -> SMTP -> noop
# Optional override:
# VIVD_EMAIL_PROVIDER=smtp                # resend | ses | smtp | noop
# Legacy alias still supported: EMAIL_PROVIDER
# VIVD_EMAIL_FROM=noreply@mail.vivd.studio   # preferred sender env
# VIVD_FROM_EMAIL=noreply@mail.vivd.studio   # legacy alias
#
# SMTP (generic self-host send-only option; no bounce/complaint webhooks yet)
# VIVD_SMTP_URL=smtps://user:pass@smtp.example.com:465
# or:
# VIVD_SMTP_HOST=smtp.example.com
# VIVD_SMTP_PORT=587
# VIVD_SMTP_SECURE=false
# VIVD_SMTP_USER=...
# VIVD_SMTP_PASSWORD=...
# VIVD_SMTP_REQUIRE_TLS=false
# VIVD_SMTP_IGNORE_TLS=false
# VIVD_SMTP_FROM_EMAIL=noreply@mail.vivd.studio
#
# Optional transactional email identity/footer. Leave unset to keep emails minimal.
# These values can also be managed later in Instance Settings -> Email.
# VIVD_EMAIL_BRAND_DISPLAY_NAME=Example Studio
# VIVD_EMAIL_BRAND_LOGO_URL=https://example.com/logo.png
# VIVD_EMAIL_BRAND_SUPPORT_EMAIL=support@example.com
# VIVD_EMAIL_BRAND_WEBSITE_URL=https://example.com
# VIVD_EMAIL_BRAND_LEGAL_NAME=Example GmbH
# VIVD_EMAIL_BRAND_LEGAL_ADDRESS=Street 1, 12345 City
# VIVD_EMAIL_BRAND_IMPRINT_URL=https://example.com/imprint
# VIVD_EMAIL_BRAND_PRIVACY_URL=https://example.com/privacy
# VIVD_EMAIL_BRAND_TERMS_URL=https://example.com/terms
#
# Resend
# RESEND_API_KEY=re_xxx
# RESEND_WEBHOOK_SECRET=whsec_xxx
#
# SES
# VIVD_SES_REGION=eu-central-1
# VIVD_SES_ACCESS_KEY_ID=...
# VIVD_SES_SECRET_ACCESS_KEY=...
# VIVD_SES_FROM_EMAIL=noreply@mail.vivd.studio
# SES feedback webhook for bounce/complaint notifications (SNS -> HTTPS endpoint)
# Endpoint: /email/v1/feedback/ses
# Optional shared-secret guard (append `?secret=...` in SNS subscription URL)
# VIVD_SES_FEEDBACK_WEBHOOK_SECRET=...
# Optional: auto-confirm SNS subscriptions on first handshake POST
# VIVD_SES_FEEDBACK_AUTO_CONFIRM=false
# Global deliverability policy defaults (shown in Super Admin -> Email)
# VIVD_CONTACT_FORM_AUTO_SUPPRESS_BOUNCES=true
# VIVD_CONTACT_FORM_AUTO_SUPPRESS_COMPLAINTS=true
# VIVD_CONTACT_FORM_COMPLAINT_RATE_THRESHOLD_PERCENT=0.1
# VIVD_CONTACT_FORM_BOUNCE_RATE_THRESHOLD_PERCENT=5

# Auth email behavior (verification + password reset)
# VIVD_AUTH_REQUIRE_EMAIL_VERIFICATION=false
# VIVD_AUTH_EMAIL_VERIFICATION_SEND_ON_SIGNUP=true
# VIVD_AUTH_EMAIL_VERIFICATION_SEND_ON_SIGNIN=false
# VIVD_AUTH_EMAIL_VERIFICATION_AUTO_SIGNIN=false
# VIVD_AUTH_EMAIL_VERIFICATION_EXPIRES_IN_SECONDS=3600
# VIVD_AUTH_RESET_PASSWORD_EXPIRES_IN_SECONDS=3600
# VIVD_AUTH_REVOKE_SESSIONS_ON_PASSWORD_RESET=true
# Frontend gate for post-login verification prompt (disabled by default)
# VITE_EMAIL_VERIFICATION_PROMPT_ENABLED=false

# Contact form submission retention
# Set to 0 to disable automatic deletion.
# By default, recipients must be verified (org-member verification or email-link verification).
# VIVD_CONTACT_FORM_REQUIRE_VERIFIED_RECIPIENTS=true
# Contact recipient verification email flow (optional; defaults shown)
# VIVD_CONTACT_FORM_RECIPIENT_VERIFY_EXPIRES_IN_SECONDS=86400
# VIVD_CONTACT_FORM_RECIPIENT_VERIFY_RESEND_COOLDOWN_SECONDS=60
# VIVD_CONTACT_FORM_RECIPIENT_VERIFY_MAX_PENDING=100
# VIVD_CONTACT_FORM_RETENTION_DAYS=30
# VIVD_CONTACT_FORM_RETENTION_CLEANUP_INTERVAL_MS=21600000

# Contact form anti-abuse controls (optional; defaults shown)
# Keep human retries possible while blocking rapid-fire or duplicate spam.
# Set any value to 0 to disable that specific guard.
# VIVD_CONTACT_FORM_MIN_REPEAT_SECONDS=2
# VIVD_CONTACT_FORM_RATE_LIMIT_PER_IP_PER_MINUTE=10
# VIVD_CONTACT_FORM_RATE_LIMIT_PER_IP_PER_HOUR=120
# VIVD_CONTACT_FORM_RATE_LIMIT_PER_TOKEN_PER_MINUTE=60
# VIVD_CONTACT_FORM_RATE_LIMIT_PER_TOKEN_PER_HOUR=1000
# VIVD_CONTACT_FORM_DUPLICATE_WINDOW_SECONDS=45
# VIVD_CONTACT_FORM_MAX_TOTAL_FIELD_CHARS=8000
# VIVD_CONTACT_FORM_MAX_SINGLE_FIELD_CHARS=2000
# VIVD_CONTACT_FORM_MAX_LINKS_PER_SUBMISSION=5

# Analytics anti-abuse controls (optional; defaults shown)
# VIVD_ANALYTICS_RATE_LIMIT_PER_TOKEN_PER_MINUTE=240
#
# Analytics geolocation (optional; powers the Analytics country breakdown)
# - auto: use provider country headers when present; otherwise try MaxMind GeoLite2 lookup
# - headers: only use proxy/CDN country headers (Cloudflare, Vercel, CloudFront, Fastly)
# - maxmind: only use MaxMind GeoLite2 country lookup from client IP
# - off: disable analytics geolocation entirely
# VIVD_ANALYTICS_GEOLOCATION_MODE=auto
# Mount a GeoLite2 Country .mmdb file into the backend container and point this at it for
# provider-agnostic country detection on generic self-host installs.
# VIVD_ANALYTICS_GEOIP_DB_PATH=/app/geoip/GeoLite2-Country.mmdb
# Optional helper-script credentials for `./scripts/install-analytics-geoip.sh`
# MAXMIND_ACCOUNT_ID=your_account_id
# MAXMIND_LICENSE_KEY=your_license_key

# Contact form Turnstile automation (optional, needed when enabling Turnstile per project in Super Admin)
# CLOUDFLARE_ACCOUNT_ID=...
# CLOUDFLARE_API_TOKEN=...

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=landing_agent

# Scraper service authentication (used by backend to call scraper)
SCRAPER_API_KEY=your-secure-api-key-here
# Optional override when using an external scraper service.
# Docker Compose defaults this internally to http://scraper:3001.
# SCRAPER_URL=http://scraper:3001
# Optional thumbnail-preview base override for advanced setups.
# In the bundled self-host Docker stack this is inferred automatically and usually does not need to be set.
# Useful if thumbnails should fetch previews from a different internal or public origin than the default.
# VIVD_THUMBNAIL_PREVIEW_BASE_URL=http://backend:3000
# Optional internal scraper tuning (defaults shown)
# MAX_BROWSERS=2
# MAX_CONCURRENT_SCRAPES=2
# Optional scraper residential proxy (used by the scraper's Puppeteer browser)
# Enable by setting PROXY_HOST; auth is only sent when username/password are set.
# PROXY_HOST=proxy.example.com
# PROXY_PORT=823
# PROXY_USERNAME=...
# PROXY_PASSWORD=...

# Studio Machine Storage (S3/R2)
# Studio machines hydrate project files from object storage into a local workspace directory
# and periodically sync changes back (see `packages/studio/entrypoint.sh`).
# Local provider (`STUDIO_MACHINE_PROVIDER=local`) uses the same variables for local
# hydrate/sync without requiring the studio container entrypoint.
#
# For remote S3-compatible storage, prefer the generic envs:
# VIVD_S3_BUCKET=my-platform-bucket
# VIVD_S3_ENDPOINT_URL=https://s3.example.com
# VIVD_S3_ACCESS_KEY_ID=xxx
# VIVD_S3_SECRET_ACCESS_KEY=yyy
# VIVD_S3_REGION=eu-central-1
# Optional:
# VIVD_S3_SESSION_TOKEN=...
# VIVD_S3_PUBLIC_BASE_URL=https://cdn.example.com
# VIVD_S3_DOWNLOAD_ENDPOINT_URL=https://objects.example.com
#
# Cloudflare R2 remains supported via compatibility aliases:
# R2_BUCKET=my-platform-bucket
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# R2_ACCESS_KEY=xxx
# R2_SECRET_KEY=yyy
#
# Self-host installs can instead run a local S3-compatible bucket:
# VIVD_BUCKET_MODE=local                            # local | external
# VIVD_LOCAL_S3_BUCKET=vivd
# VIVD_LOCAL_S3_ENDPOINT_URL=http://minio:9000
# VIVD_LOCAL_S3_DOWNLOAD_ENDPOINT_URL=http://localhost/_vivd_s3
# VIVD_LOCAL_S3_ACCESS_KEY=vivdlocal
# VIVD_LOCAL_S3_SECRET_KEY=changeme
# VIVD_LOCAL_S3_REGION=us-east-1
#
# Optional (overrides how the entrypoint computes the bucket path):
# VIVD_S3_PREFIX=tenants/default/projects/my-project/v1
# VIVD_S3_SOURCE_URI=s3://my-platform-bucket/tenants/default/projects/my-project/v1/source
# VIVD_S3_OPENCODE_PREFIX=tenants/default/projects/my-project/opencode
# VIVD_S3_OPENCODE_URI=s3://my-platform-bucket/tenants/default/projects/my-project/opencode
# VIVD_S3_SYNC_INTERVAL_SECONDS=30
# Experimental dedicated artifact builder path for preview/published Astro builds.
# Default is off; Studio keeps using the current in-runtime build path until this is enabled.
# VIVD_ARTIFACT_BUILDER_ENABLED=false
# Dedicated builder image/tag selection (usually keep tags aligned with the Studio image tag):
# DOCKER_BUILDER_IMAGE_REPO=ghcr.io/vivd-studio/vivd-builder
# DOCKER_BUILDER_IMAGE=ghcr.io/vivd-studio/vivd-builder:dev-abc1234
# DOCKER_BUILDER_CPUS=1
# DOCKER_BUILDER_MEMORY_MB=4096
# FLY_BUILDER_IMAGE_REPO=ghcr.io/vivd-studio/vivd-builder
# FLY_BUILDER_IMAGE=ghcr.io/vivd-studio/vivd-builder:v1.0.0
# FLY_BUILDER_CPU_KIND=performance
# FLY_BUILDER_CPUS=1
# FLY_BUILDER_MEMORY_MB=4096
# Optional builder guardrails:
# VIVD_BUILDER_INSTALL_TIMEOUT_MS=900000
# VIVD_BUILDER_BUILD_TIMEOUT_MS=900000
# VIVD_BUILDER_INSTALL_MAX_OLD_SPACE_MB=1024
# VIVD_BUILDER_ASTRO_MAX_OLD_SPACE_MB=1536
# VIVD_WORKSPACE_DIR=/home/studio/project        # default inside studio machines
# VIVD_OPENCODE_DATA_HOME=/home/studio/opencode-data
# VIVD_PACKAGE_CACHE_DIR=/home/studio/opencode-data/package-cache
# OPENCODE_SERVER_READY_TIMEOUT_MS=120000        # allow slower OpenCode boots on larger workspaces
# STUDIO_OPENCODE_SOFT_CONTEXT_LIMIT_TOKENS=250000  # start compacting long chats around this token count
# DEVSERVER_INSTALL_TIMEOUT_MS=900000            # 15m install timeout for large Astro deps
# DEVSERVER_NODE_MODULES_CACHE=1                 # cache node_modules archive per lockfile
# VIVD_SYNC_PAUSE_FILE=/tmp/vivd-sync.pause      # studio sets while installing deps to pause S3 sync
# VIVD_SYNC_PAUSE_MAX_AGE_SECONDS=600
# STUDIO_HOST=0.0.0.0                            # explicit bind host for studio HTTP server
# # Studio access control (optional)
# # When set, @vivd/studio requires a token for tRPC + file/upload endpoints.
# # Fly studio machines get a per-machine token automatically; local provider leaves this unset by default.
# # STUDIO_ACCESS_TOKEN=changeme
# # Optional dedicated signing secret for delegated Studio user-action tokens.
# # Defaults to BETTER_AUTH_SECRET when unset; only override if you want explicit separation.
# # VIVD_STUDIO_USER_ACTION_TOKEN_SECRET=changeme
# # OpenCode sessions are stored in $XDG_DATA_HOME/opencode/storage
# # and are synced via VIVD_S3_OPENCODE_{PREFIX,URI}, separate from source code.

# Single Project Mode (for single-project licenses)
# When true, the app operates with a single project and bypasses the project list
# Defaults to false when unset.
# SINGLE_PROJECT_MODE=true

# Usage Limits (optional - defaults shown)
# Controls instance-wide cost and image generation limits
# LICENSE_DAILY_CREDIT_LIMIT=20
# LICENSE_WEEKLY_CREDIT_LIMIT=50
# LICENSE_MONTHLY_CREDIT_LIMIT=100
# LICENSE_IMAGE_GEN_PER_MONTH=50
# LICENSE_WARNING_THRESHOLD=0.8

# Upload Limits (optional)
# ZIP_IMPORT_MAX_FILE_SIZE_MB=250

# Project storage (filesystem tenant prep)
# New projects are stored under: projects/tenants/<PROJECTS_TENANT_ID>/<slug>/v<version>/
# Legacy projects at projects/<slug>/v<version>/ are still supported.
# PROJECTS_TENANT_ID=default

# GitHub sync (optional backup)
# Pushes the local project repo state to a GitHub org repo on publish/save.
# Repo name pattern: <GITHUB_REPO_PREFIX><tenantId>-<slug>-v<version>
# GITHUB_SYNC_ENABLED=false
# GITHUB_SYNC_STRICT=false          # If true, failures throw (best-effort is recommended)
# GITHUB_ORG=your-github-org
# GITHUB_TOKEN=ghp_xxx
# GITHUB_REPO_PREFIX=dev-           # Optional; e.g. dev-, staging-
# GITHUB_REPO_VISIBILITY=private    # private | public | internal
# GITHUB_API_URL=https://api.github.com
# GITHUB_GIT_HOST=github.com

# Studio Machines Provider
# - local: spawns @vivd/studio as a child process inside the backend container
# - fly: provisions isolated Fly.io Machines (local-first testing supported)
# - docker: provisions isolated containers on one Docker host and exposes them through Caddy path routes
# Docker self-host live preview can also allocate real runtime origins by port.
# Set `DOCKER_STUDIO_PUBLIC_PORT_START` if you want to move the default port range.
# STUDIO_MACHINE_PROVIDER=local

# Fly.io Studio Machines (when STUDIO_MACHINE_PROVIDER=fly)
# Important: The studio machine must be able to reach the backend URL for usage reporting.
# For local-first testing, expose your local Caddy (port 80) via a tunnel and set BACKEND_URL to it.
# BACKEND_URL=https://your-tunnel.example
#
# FLY_API_TOKEN=fly_xxx
# FLY_STUDIO_APP=vivd-studio-dev
# Studio image selection:
# - default: auto-picks latest semver tag from ghcr.io/vivd-studio/vivd-studio
# - optional override: change auto source repository
# FLY_STUDIO_IMAGE_REPO=ghcr.io/vivd-studio/vivd-studio
# - optional override: pin image explicitly with FLY_STUDIO_IMAGE
# FLY_STUDIO_IMAGE=ghcr.io/vivd-studio/vivd-studio:0.2.2
# Note: Fly machine region is immutable; changing FLY_STUDIO_REGION requires destroying/recreating existing studio machines.
# FLY_STUDIO_REGION=fra
# FLY_STUDIO_PORT_START=3100
# FLY_STUDIO_PUBLIC_HOST=vivd-studio-dev.fly.dev
# FLY_STUDIO_PUBLIC_PROTOCOL=https
# FLY_STUDIO_CPU_KIND=shared                  # shared | performance
# FLY_STUDIO_CPUS=1
# FLY_STUDIO_MEMORY_MB=1024                   # performance mode auto-clamped to Fly minimums (>=4096)
# Backend keepalive timeout (explicitly suspend/stop studio after no frontend heartbeat)
# FLY_STUDIO_IDLE_TIMEOUT_MS=600000
# FLY_STUDIO_IDLE_CHECK_INTERVAL_MS=30000
# Agent-run keepalive lease (connected studio reports active agent runs to backend).
# Heartbeats keep machines alive while agents are busy even if no browser tab is open.
# Hard cap prevents endless uptime for stuck runs; once exceeded, keepalive stops and
# regular idle timeout applies.
# AGENT_LEASE_HEARTBEAT_MS=20000
# AGENT_LEASE_TTL_MS=90000
# AGENT_LEASE_MAX_MS=2700000
# Reconciler inactivity GC window (days without studio visits before destroy)
# FLY_STUDIO_RECONCILER_MAX_MACHINE_INACTIVITY_DAYS=7
# Legacy alias still supported: FLY_STUDIO_RECONCILER_MAX_MACHINE_AGE_DAYS
# FLY_STUDIO_ENV_PASSTHROUGH=GOOGLE_API_KEY,OPENROUTER_API_KEY,GOOGLE_CLOUD_PROJECT,VERTEX_LOCATION,GOOGLE_APPLICATION_CREDENTIALS,GOOGLE_APPLICATION_CREDENTIALS_JSON,VIVD_GOOGLE_APPLICATION_CREDENTIALS_PATH,OPENCODE_MODEL_STANDARD,OPENCODE_MODEL_STANDARD_VARIANT,OPENCODE_MODEL_ADVANCED,OPENCODE_MODEL_ADVANCED_VARIANT,OPENCODE_MODEL_PRO,OPENCODE_MODEL_PRO_VARIANT
#
# OpenCode model tiers (Studio chat / initial generation)
# Initial generation prefers the advanced tier when it is set.
# The self-host installer writes the first two defaults automatically.
# OPENCODE_MODEL_STANDARD=openrouter/google/gemini-3-flash-preview
# OPENCODE_MODEL_STANDARD_VARIANT=
# OPENCODE_MODEL_ADVANCED=openrouter/google/gemini-3.1-pro-preview
# OPENCODE_MODEL_ADVANCED_VARIANT=
# OPENCODE_MODEL_PRO=openrouter/google/gemini-3.1-pro-preview   # optional
# OPENCODE_MODEL_PRO_VARIANT=high                               # optional OpenCode variant, e.g. high

# Single-host Docker Studio Machines (when STUDIO_MACHINE_PROVIDER=docker)
# Runtime routes are proxied through Caddy on a path prefix such as /_studio/<route-id>.
# The backend must be able to talk to the Docker Engine API and write route snippets into
# the shared runtime-routes directory mounted into Caddy.
# DOCKER_STUDIO_SOCKET_PATH=/var/run/docker.sock
# DOCKER_STUDIO_API_BASE_URL=                       # optional alternative to the Unix socket, e.g. http://docker-proxy:2375
# DOCKER_STUDIO_API_VERSION=v1.44
# CADDY_RUNTIME_ROUTES_DIR=/etc/caddy/runtime.d
# DOCKER_STUDIO_NETWORK=vivd-network               # created runtime containers join this Docker network
# DOCKER_STUDIO_ROUTE_PREFIX=/_studio
# When the native host platform has no manifest for the selected studio image,
# Docker provider retries with this platform. Set blank to disable fallback.
# DOCKER_STUDIO_FALLBACK_PLATFORM=linux/amd64
# DOCKER_STUDIO_PUBLIC_BASE_URL=https://app.yourdomain.com
# DOCKER_STUDIO_INTERNAL_PROXY_BASE_URL=http://caddy
# DOCKER_STUDIO_MAIN_BACKEND_URL=http://backend:3000/vivd-studio
# Studio image selection:
# - default: auto-picks latest semver tag from ghcr.io/vivd-studio/vivd-studio
# - optional override: change auto source repository
# DOCKER_STUDIO_IMAGE_REPO=ghcr.io/vivd-studio/vivd-studio
# - optional override: pin image explicitly with DOCKER_STUDIO_IMAGE
# DOCKER_STUDIO_IMAGE=ghcr.io/vivd-studio/vivd-studio:0.2.2
# Managed self-host UI updates:
# - only enable this when the backend container can see the host compose bundle path
# - the public solo self-host bundle wires these automatically
# VIVD_SELFHOST_UPDATE_WORKDIR=/srv/selfhost
# VIVD_SELFHOST_UPDATE_SERVICES=backend frontend scraper
# VIVD_SELFHOST_UPDATE_HELPER_IMAGE=docker:28-cli
# Optional explicit CPU override. If unset, Vivd auto-sizes Docker studio CPU
# from the detected CPU budget, leaves one CPU for the rest of the stack, and
# caps the default auto-sized result at 2 CPUs.
# DOCKER_STUDIO_CPUS=2
# DOCKER_STUDIO_CPUS_AUTO_RESERVE=1
# DOCKER_STUDIO_CPUS_AUTO_MAX=2
# Optional explicit studio memory override. If unset, Vivd auto-sizes Docker
# studio memory from the detected host/cgroup memory budget, subtracting a
# reserve for the rest of the stack, and caps the default auto-sized result at
# 4096 MiB.
# DOCKER_STUDIO_MEMORY_MB=4096
# DOCKER_STUDIO_MEMORY_AUTO_RESERVE_MB=1536
# Optional floor if you prefer to trade some reserve for more Studio RAM on
# very small boxes.
# DOCKER_STUDIO_MEMORY_AUTO_MIN_MB=1024
# Default cap for larger hosts; raise it if your Studio workloads need more.
# DOCKER_STUDIO_MEMORY_AUTO_MAX_MB=4096
# Backend keepalive timeout (explicitly stop studio after no frontend heartbeat)
# DOCKER_STUDIO_IDLE_TIMEOUT_MS=600000
# DOCKER_STUDIO_IDLE_CHECK_INTERVAL_MS=30000
# Reconciler inactivity GC window (days without studio visits before destroy)
# DOCKER_STUDIO_RECONCILER_MAX_MACHINE_INACTIVITY_DAYS=7

# Playwright host-smoke harness
# Uses a dedicated local host port so the browser smoke can hit app.localhost/default.localhost
# without taking over your normal dev stack on :80.
# VIVD_STUDIO_HOST_SMOKE_PORT=18080
# VIVD_STUDIO_HOST_SMOKE_HEADLESS=false
# VIVD_STUDIO_HOST_SMOKE_DEVTOOLS=true
# VIVD_STUDIO_HOST_SMOKE_SLOW_MO_MS=250
# VIVD_STUDIO_HOST_SMOKE_PAUSE_ON_FAILURE=true
# Dedicated cheap model for smoke runs; defaults to openrouter/google/gemini-2.5-flash-lite
# VIVD_STUDIO_HOST_SMOKE_MODEL=openrouter/google/gemini-2.5-flash-lite
# Use PWDEBUG=1 only when you explicitly want Playwright Inspector step-through mode.
